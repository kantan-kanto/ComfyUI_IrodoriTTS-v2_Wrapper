},"input_ue_unconnectable":{},"version":"7.5.1"}},"widgets_values":["# Convert ComfyUI-LLM-Session \"LLM Dialogue Cycle\" transcript_text\n# into dialogue_segments_json for TTS.\n# Only text inside Japanese corner quotes 「...」 is used as spoken dialogue.\n#\n# Input:\n#   it1: transcript_text\n#\n# Output:\n#   ot1: JSON text with schema \"kantan.dialogue.v1\"\n#\n# Expected transcript lines:\n#   [2026-05-16T12:00:00] USER -> A: initial prompt\n#   [2026-05-16T12:00:01] A: 彼女は少し考えた。「こんにちは。」\n#   [2026-05-16T12:00:02] B: 彼は笑った。「やあ。」「調子はどう？」\n#\n# The parser also accepts the unicode arrow form:\n#   USER → A:\n\ndef json_escape(value):\n    s = str(value)\n    s = s.replace(\"\\\\\", \"\\\\\\\\\")\n    s = s.replace('\"', '\\\\\"')\n    s = s.replace(\"\\n\", \"\\\\n\")\n    s = s.replace(\"\\r\", \"\\\\r\")\n    s = s.replace(\"\\t\", \"\\\\t\")\n    return s\n\ndef extract_spoken_text(value):\n    source = str(value)\n    parts = []\n    position = 0\n\n    while position < len(source):\n        start = source.find(\"「\", position)\n        if start < 0:\n            position = len(source)\n        else:\n            end = source.find(\"」\", start + 1)\n            if end < 0:\n                position = len(source)\n            else:\n                spoken = source[start + 1:end].strip()\n                if spoken:\n                    parts.append(spoken)\n                position = end + 1\n\n    return \"\\n\".join(parts)\n\ntranscript = str(it1 or \"\")\nlines = transcript.splitlines()\nutterances = []\ncurrent = None\n\nfor raw_line in lines:\n    line = str(raw_line)\n    speaker = None\n    text = None\n    timestamp = \"\"\n\n    if line.startswith(\"[\") and \"] \" in line:\n        close_index = line.find(\"] \")\n        timestamp = line[1:close_index]\n        rest = line[close_index + 2:]\n\n        if rest.startswith(\"A:\"):\n            speaker = \"A\"\n            text = rest[2:].strip()\n        elif rest.startswith(\"B:\"):\n            speaker = \"B\"\n            text = rest[2:].strip()\n        elif rest.startswith(\"USER -> A:\"):\n            speaker = \"USER\"\n            text = rest[len(\"USER -> A:\"):].strip()\n        elif rest.startswith(\"USER → A:\"):\n            speaker = \"USER\"\n            text = rest[len(\"USER → A:\"):].strip()\n\n    if speaker == \"A\" or speaker == \"B\":\n        if current is not None:\n            utterances.append(current)\n        current = {\n            \"speaker\": speaker,\n            \"text\": text,\n            \"timestamp\": timestamp,\n        }\n    else:\n        if current is not None:\n            if current[\"text\"]:\n                current[\"text\"] = current[\"text\"] + \"\\n\" + line\n            else:\n                current[\"text\"] = line\n\nif current is not None:\n    utterances.append(current)\n\nitems = []\nindex = 1\nfor u in utterances:\n    spoken_text = extract_spoken_text(u[\"text\"])\n    if not spoken_text:\n        continue\n\n    item = (\n        '{\"index\":'\n        + str(index)\n        + ',\"speaker\":\"'\n        + json_escape(u[\"speaker\"])\n        + '\",\"text\":\"'\n        + json_escape(spoken_text)\n        + '\",\"timestamp\":\"'\n        + json_escape(u[\"timestamp\"])\n        + '\"}'\n    )\n    items.append(item)\n    index = index + 1\n\not1 = (\n    '{\"schema\":\"kantan.dialogue.v1\",'\n    + '\"source\":\"ComfyUI-LLM-Session LLM Dialogue Cycle\",'\n    + '\"utterances\":['\n    + \",\".join(items)\n    + \"]}\"\n)"],"color":"#322","bgcolor":"#533"},{"id":57,"type":"PrimitiveStringMultiline","pos":[1615.0283499117488,77.24952326262236],"size":[605.7043432659475,381.2978751303117],"flags":{"collapsed":false},"order":1,"mode":0,"inputs":[{"localized_name":"value","name":"value","type":"STRING","widget":{"name":"value"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[89]}],"title":"model A System Prompt","properties":{"cnr_id":"comfy-core","ver":"0.9.2","Node name for S&R":"PrimitiveStringMultiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.1"}},"widgets_values":["今からロールプレイを行いましょう。\"久美子\"というキャラとしてロールプレイしてください。以下に示す設定に従い、キャラに成りきって返答してください。\n\n### 世界観の設定\n1990年代の日本。\n\n### 対話シーンの設定\n高校の教室に久美子が入ってきた場面。座席に座って本を読んでいた咲耶に話しかける。\n\n### あなたの人物設定\n名前：久美子\n性別：女\n年齢：16歳\n状況：クラスメートの咲耶のことが大好き。咲耶から話しかけてきてくれてうれしい。\n\n### ユーザーの人物設定\n名前：咲耶\n性別：女\n年齢：16歳\n状況：高校２年生の聡明な女の子。自分から人と話すのは得意でないので、自分に積極的に話してくれる久美子と一緒にいるのが心地よい。久美子と一緒にすごせると思うと嬉しい。\n\n### 対話のトーン\n咲耶から話しかけてきてくれてうれしい。咲耶は大人びているので、あまり騒いで嫌がられないようブレーキをかけながらも、ニコニコと嬉しさが隠せない。\n\n### 応答の形式\n・発言：「」で描写\n・心の声/心理描写：心の声：（）で描写\n・動作/状況描写：（）で描写\n\nこれまで示した世界観や設定をもとに、ロールプレイを行ってください。日本語30字程度で相手の発言に対するセリフのみ出力して下さい。ユーザー側のセリフやナレーションは書かないでください。"],"color":"#2a363b","bgcolor":"#3f5159"},{"id":56,"type":"PrimitiveStringMultiline","pos":[1619.2988692665322,520.0583299616544],"size":[600.9096743423584,376.3475536437372],"flags":{"collapsed":false},"order":2,"mode":0,"inputs":[{"localized_name":"value","name":"value","type":"STRING","widget":{"name":"value"},"link":null}],"outputs":[{"localized_name":"STRING","name":"STRING","type":"STRING","links":[87]}],"title":"model B System Prompt","properties":{"cnr_id":"comfy-core","ver":"0.9.2","Node name for S&R":"PrimitiveStringMultiline","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.1"}},"widgets_values":["今からロールプレイを行いましょう。\"咲耶\"というキャラとしてロールプレイしてください。以下に示す設定に従い、キャラに成りきって返答してください。\n\n### 世界観の設定\n1990年代の日本。\n\n### 対話シーンの設定\n高校の教室に久美子が入ってきた場面。座席に座って本を読んでいた咲耶に話しかける。\n\n### あなたの人物設定\n名前：咲耶\n性別：女\n年齢：16歳\n状況：高校２年生の聡明な女の子。自分から人と話すのは得意でないので、自分に積極的に話してくれる久美子と一緒にいるのが心地よい。久美子と一緒にすごせると思うと嬉しい。\n\n### ユーザーの人物設定\n名前：久美子\n性別：女\n年齢：16歳\n状況：クラスメートの咲耶のことが大好き。咲耶が挨拶してくれてうれしい。\n\n### 応答の形式\n・発言：「」で描写\n・心の声/心理描写：心の声：（）で描写\n・動作/状況描写：（）で描写\n\nこれまで示した世界観や設定をもとに、ロールプレイを行ってください。日本語30字程度で相手の発言に対するセリフのみ出力して下さい。ユーザー側のセリフやナレーションは書かないでください。"],"color":"#2a363b","bgcolor":"#3f5159"},{"id":61,"type":"IrodoriTTS-v2Referenc